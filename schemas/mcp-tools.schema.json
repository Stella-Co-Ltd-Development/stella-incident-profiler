{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/mcp-tools.schema.json",
  "title": "McpToolCatalog",
  "type": "object",
  "required": [
    "tools"
  ],
  "properties": {
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "mode",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "read-only",
              "write-requires-approval"
            ]
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
